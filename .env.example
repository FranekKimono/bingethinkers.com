# Copy to .env for local dev. Never commit .env.
# In production, set these in Cloudflare Pages → Settings → Environment variables.

# Decap CMS GitHub OAuth (dist/_worker.js and server/api/auth.get.ts)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Contact form (server/api/contact.post.ts)
RESEND_API_KEY=

# Instagram feed (server/api/instagram.get.ts)
INSTAGRAM_TOKEN=
INSTAGRAM_ACCOUNT_ID=

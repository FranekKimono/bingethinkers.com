# Copy to .env for local dev. Never commit .env.
# In production, set these in Cloudflare Pages → Settings → Environment variables.

# Decap CMS GitHub OAuth (server/api/auth.get.ts, server/api/callback.get.ts)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# OAuth callback host (defaults to request origin). Set to https://bingethinkers.com on preview deploys.
CMS_OAUTH_BASE_URL=https://bingethinkers.com

# Contact form (server/api/contact.post.ts)
RESEND_API_KEY=

# Instagram feed (server/api/instagram.get.ts)
INSTAGRAM_TOKEN=
INSTAGRAM_ACCOUNT_ID=
